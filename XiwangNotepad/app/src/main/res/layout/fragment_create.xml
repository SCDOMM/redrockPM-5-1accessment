<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_margin="15dp"
    tools:context=".view.fragment.CreateFragment"
    android:fitsSystemWindows="true"
    >

    <TextView
        android:id="@+id/create_tv_title1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="待办名称"
        android:textSize="20sp"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.textfield.TextInputEditText
        android:id="@+id/create_etv_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/sky_blue"
        android:hint="输入待办名称"
        android:padding="5dp"
        android:textColorHint="	#BEBEBE"
        app:layout_constraintTop_toBottomOf="@id/create_tv_title1" />

    <ImageView
        android:id="@+id/create_iv_divider1"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginVertical="10dp"
        android:background="#BEBEBE"
        app:layout_constraintTop_toBottomOf="@id/create_etv_name" />

    <TextView
        android:id="@+id/create_tv_title2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="截止时间"
        android:textSize="20sp"
        app:layout_constraintTop_toBottomOf="@id/create_iv_divider1" />

    <TextView
        android:id="@+id/create_etv_time"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="设置截止时间"
        android:padding="5dp"
        android:textColorHint="#BEBEBE"
        android:textSize="18sp"
        app:layout_constraintTop_toBottomOf="@id/create_tv_title2" />

    <ImageView
        android:id="@+id/create_iv_divider2"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginVertical="5dp"
        android:background="#BEBEBE"
        app:layout_constraintTop_toBottomOf="@id/create_etv_time" />

    <TextView
        android:id="@+id/create_tv_title3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"
        android:text="备注"
        android:textSize="20dp"
        app:layout_constraintTop_toBottomOf="@id/create_etv_time" />

    <com.google.android.material.textfield.TextInputEditText
        android:id="@+id/create_etv_remark"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="设置备注"
        android:textColorHint="#BEBEBE"
        app:layout_constraintTop_toBottomOf="@id/create_tv_title3" />
    <com.google.android.material.button.MaterialButton
        android:id="@+id/create_btn_confirm"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="提交"
        app:layout_constraintTop_toBottomOf="@id/create_etv_remark" />



</androidx.constraintlayout.widget.ConstraintLayout>
